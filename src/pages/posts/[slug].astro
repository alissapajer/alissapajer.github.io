---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import { slugFromUrl, urlize } from "../../site";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const paths = [];
  for (const post of posts) {
    // The canonical page at the pinned URL.
    paths.push({
      params: { slug: slugFromUrl(post.data.url) },
      props: { post, redirectTo: null as string | null },
    });
    // A redirect stub for every legacy alias.
    for (const alias of post.data.aliases) {
      paths.push({
        params: { slug: slugFromUrl(alias) },
        props: { post, redirectTo: post.data.url },
      });
    }
  }
  return paths;
}

interface Props {
  post: CollectionEntry<"posts">;
  redirectTo: string | null;
}

const { post, redirectTo } = Astro.props;

const fmtLong = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });

// Alias pages render a bare meta-refresh redirect (matching Hugo aliases).
const canonical = redirectTo ? new URL(redirectTo, Astro.site).href : null;

const { Content } = redirectTo
  ? { Content: null }
  : await render(post);
---

{
  redirectTo ? (
    <html lang="en">
      <head>
        <meta charset="utf-8" />
        <title>{canonical}</title>
        <link rel="canonical" href={canonical} />
        <meta name="robots" content="noindex" />
        <meta http-equiv="refresh" content={`0; url=${redirectTo}`} />
      </head>
      <body>
        <p>
          This page has moved to <a href={redirectTo}>{redirectTo}</a>.
        </p>
      </body>
    </html>
  ) : (
    <Base title={post.data.title}>
      <article class="post">
        <header class="post-header">
          <h1>{post.data.title}</h1>
          <div class="post-meta">
            <time datetime={post.data.date.toISOString().slice(0, 10)}>
              {fmtLong(post.data.date)}
            </time>
            {post.data.tags.length > 0 && (
              <span class="post-tags">
                {post.data.tags.map((t) => (
                  <a href={`/tags/${urlize(t)}/`}>#{t}</a>
                ))}{" "}
              </span>
            )}
          </div>
        </header>
        <div class="post-content">
          <Content />
        </div>
      </article>
    </Base>
  )
}
